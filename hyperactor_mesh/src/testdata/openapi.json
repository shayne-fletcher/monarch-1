        "operationId": "getErrorSchema",
        "responses": {
          "200": {
            "content": {
              "application/json": {}
            },
            "description": "JSON Schema document"
          }
        },
        "summary": "JSON Schema for ApiErrorEnvelope (Draft 2020-12)"
      }
    },
    "/v1/tree": {
      "get": {
        "operationId": "getTree",
        "responses": {
          "200": {
            "content": {
              "text/plain": {}
            },
            "description": "Human-readable topology tree"
          }
        },
        "summary": "ASCII topology dump (debug)"
      }
    },
    "/v1/{reference}": {
      "get": {
        "operationId": "resolveReference",
        "parameters": [
          {
            "description": "URL-encoded opaque reference string",
            "in": "path",
            "name": "reference",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NodePayload"
                }
              }
            },
            "description": "Resolved NodePayload"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            },
            "description": "Bad request (malformed reference)"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            },
            "description": "Reference not found"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            },
            "description": "Internal error"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            },
            "description": "Service unavailable (at capacity, retry with backoff)"
          },
          "504": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorEnvelope"
                }
              }
            },
            "description": "Gateway timeout (downstream host unresponsive)"
          }
        },
        "summary": "Resolve a reference to a NodePayload"
      }
    }
  }
}
