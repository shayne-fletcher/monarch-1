          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PySpyResult"
                }
              }
            },
            "description": "PySpyResult — one of Ok, BinaryNotFound, or Failed"
          },
          "400": {
            "content": {
              "application/json": {
