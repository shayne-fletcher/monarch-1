    "ActiveHandler": {
      "description": "One handler with in-flight invocations, at the HTTP boundary.",
      "properties": {
        "active_count": {
          "description": "In-flight invocations of this handler.",
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "name": {
          "description": "Handler name (e.g. a Python endpoint method name).",
          "type": "string"
