    "InboundOrdering": {
      "description": "Mesh-admin presentation of inbound ordering state.\n\nRollups marked `returned_*` are computed over `sessions` only and\nare LOWER BOUNDS when `snapshot_complete == false` (IO-6).\n`known_session_count` is the only rollup that totals returned +\nskipped sessions.",
      "properties": {
        "enabled": {
          "description": "`true` when reorder buffering is enabled for this sender.",
          "type": "boolean"
        },
        "known_session_count": {
          "description": "IO-5: `sessions.len() + skipped_session_count`. The only rollup\nthat totals returned + skipped sessions.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "returned_buffered_message_count": {
          "description": "IO-6: sum of `buffered_count` OVER RETURNED sessions.\nReorder-buffer scope only (independent of `queue_depth`; see\nIO-3). Lower bound if `!snapshot_complete`.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "returned_buffered_session_count": {
          "description": "IO-6: sessions with `buffered_count > 0` AMONG RETURNED\nsessions. Lower bound if `!snapshot_complete`.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "returned_max_buffered_count": {
          "description": "IO-6: max of `buffered_count` OVER RETURNED sessions. Lower\nbound if `!snapshot_complete`.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "sessions": {
          "description": "Per-session entries, sorted by `session_id`.",
          "items": {
            "$ref": "#/$defs/OrderingSessionSnapshot"
          },
          "type": "array"
        },
        "skipped_session_count": {
          "description": "Sessions held by a concurrent send at snapshot time.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "snapshot_complete": {
          "description": "IO-4: `true` iff `skipped_session_count == 0`.",
          "type": "boolean"
        }
      },
      "required": [
        "enabled",
        "snapshot_complete",
        "skipped_session_count",
        "known_session_count",
        "returned_buffered_session_count",
        "returned_buffered_message_count",
        "returned_max_buffered_count",
        "sessions"
      ],
      "type": "object"
    },
