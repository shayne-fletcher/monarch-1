        "active_count",
        "oldest_since"
      ],
      "type": "object"
    },
    "Execution": {
      "description": "An actor's in-flight handler execution at the HTTP boundary.\n\n`null` (absent) means the actor does not report execution\n(unsupported), not idle (EX-1). `complete == false` means the\nper-handler detail was momentarily unavailable on that read while\n`active_count` stays authoritative (EX-2).",
      "properties": {
        "active_count": {
          "description": "Handler invocations currently in flight (EX-2/EX-3).",
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "active_handlers": {
          "description": "Per-handler detail, oldest-first; a prefix of the N oldest when\n`truncated` (EX-4).",
          "items": {
            "$ref": "#/$defs/ActiveHandler"
          },
          "type": "array"
        },
        "complete": {
          "description": "`true` iff the per-handler detail was captured on this read.",
          "type": "boolean"
        },
        "truncated": {
          "description": "`true` iff `active_handlers` is a prefix of the N oldest.",
          "type": "boolean"
        }
      },
      "required": [
        "active_count",
        "active_handlers",
        "complete",
        "truncated"
      ],
      "type": "object"
    },
    "FailureInfo": {
      "description": "Structured failure information for failed actors.",
      "properties": {
        "error_message": {
